{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "postType": {
      "type": "enumeration",
      "enum": [
        "News",
        "Case Study",
        "Articles"
      ],
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "cf_createdAt": {
      "type": "datetime",
      "required": true
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tag.tag"
    },
    "mainImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "numbers": {
      "type": "json"
    },
    "content": {
      "type": "richtext"
    },
    "postTags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "string"
    },
    "seoKeywords": {
      "type": "json"
    },
    "preventIndexing": {
      "type": "boolean",
      "default": false
    }
  }
}
