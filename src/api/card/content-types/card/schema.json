{
  "kind": "collectionType",
  "collectionName": "cards",
  "info": {
    "singularName": "card",
    "pluralName": "cards",
    "displayName": "Card"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string"
    },
    "text": {
      "type": "richtext"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "ctaLabel": {
      "type": "string"
    },
    "ctaUrl": {
      "type": "string"
    },
    "ctaWillOpenModal": {
      "type": "boolean",
      "default": false
    },
    "showAddressFields": {
      "type": "boolean",
      "default": false
    },
    "address1": {
      "type": "string"
    },
    "address2": {
      "type": "string"
    },
    "bio": {
      "type": "text"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "opacity": {
      "type": "enumeration",
      "enum": [
        "light",
        "dark"
      ]
    },
    "shortDescription": {
      "type": "text"
    },
    "ctaLinkData": {
      "type": "json"
    }
  }
}
