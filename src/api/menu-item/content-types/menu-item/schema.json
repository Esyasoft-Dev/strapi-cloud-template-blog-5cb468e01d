{
  "kind": "collectionType",
  "collectionName": "menu_items",
  "info": {
    "singularName": "menu-item",
    "pluralName": "menu-items",
    "displayName": "Menu Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "text": {
      "type": "text"
    },
    "pageLink": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::page.page"
    },
    "submenuItems": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::menu-item.menu-item"
    }
  }
}
